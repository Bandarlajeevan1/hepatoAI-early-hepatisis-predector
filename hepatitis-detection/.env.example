# MongoDB Configuration
# Local MongoDB: mongodb://localhost:27017/hepatitis_db
# Docker MongoDB: mongodb://mongodb:27017/hepatitis_db (when using docker-compose)
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/hepatitis_db
MONGO_URI=mongodb://localhost:27017/hepatitis_db
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=hepatitis_db

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000
FLASK_APP=app.py

# Application Configuration
SECRET_KEY=your-secret-key-change-in-production
LOG_LEVEL=INFO
MODEL_PATH=model/trained_model.pkl

# Feature Configuration
N_NEIGHBORS_KNN=5
RSEED=42

# Risk Thresholds (probability-based, 0.0 to 1.0)
RISK_THRESHOLD_LOW=0.3
RISK_THRESHOLD_MEDIUM=0.7
